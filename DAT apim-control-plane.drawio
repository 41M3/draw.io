        <mxCell id="ERMLSZTOUcWQ_Cixsxoc-10" parent="1" style="text;html=1;align=left;verticalAlign=top;spacingTop=-4;fontSize=14;labelBackgroundColor=none;whiteSpace=wrap;" value="The developer of a feature team calls the apim-control-plane&#39;s API through the gitlab-ci configuration of their API repository." vertex="1">
          <mxGeometry height="38.5" width="449" x="202.25" y="772" as="geometry" />
        </mxCell>
        <mxCell id="ERMLSZTOUcWQ_Cixsxoc-12" parent="1" style="text;html=1;align=left;verticalAlign=top;spacingTop=-4;fontSize=14;labelBackgroundColor=none;whiteSpace=wrap;" value="&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;The API Handler&amp;nbsp;&lt;/span&gt;Lambda&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&amp;nbsp;is used to:&lt;/span&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&amp;nbsp;- Manage API state storage in the DynaboBD database;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&amp;nbsp;- Create and update the API&#39;s Apigee proxy;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&amp;nbsp;- Create and update the Apigee product;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&amp;nbsp;- Create and update documentation on the developer portal.&lt;/span&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="90" width="450" x="199.75" y="901.5" as="geometry" />
        </mxCell>
        <mxCell id="ERMLSZTOUcWQ_Cixsxoc-13" parent="1" style="text;html=1;align=left;verticalAlign=top;spacingTop=-4;fontSize=14;labelBackgroundColor=none;whiteSpace=wrap;" value="&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;The DynamoDB database stores the API metadata.&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;The S3 Storage stores the API OAS file.&lt;/span&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="38" width="450" x="202.25" y="998.5" as="geometry" />
        </mxCell>
        <mxCell id="ERMLSZTOUcWQ_Cixsxoc-14" parent="1" style="text;html=1;align=left;verticalAlign=top;spacingTop=-4;fontSize=14;labelBackgroundColor=none;whiteSpace=wrap;" value="&lt;span style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); background-color: transparent;&quot;&gt;The API Handler&amp;nbsp;&lt;/span&gt;Lambda&lt;span style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); background-color: transparent;&quot;&gt;&amp;nbsp;c&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;reate and update the API&#39;s Apigee proxy and&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;the Apigee product.&lt;br&gt;&lt;/span&gt;" vertex="1">
          <mxGeometry height="39.5" width="449" x="201.75" y="1050.5" as="geometry" />
        </mxCell>
        <mxCell id="ERMLSZTOUcWQ_Cixsxoc-15" parent="1" style="text;html=1;align=left;verticalAlign=top;spacingTop=-4;fontSize=14;labelBackgroundColor=none;whiteSpace=wrap;" value="&lt;span style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); background-color: transparent;&quot;&gt;The API Handler&amp;nbsp;&lt;/span&gt;Lambda&lt;span style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); background-color: transparent;&quot;&gt;&amp;nbsp;c&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;reate and update documentation on the developer portal.&lt;/span&gt;" vertex="1">
          <mxGeometry height="43.5" width="450" x="201.75" y="1101.5" as="geometry" />
        </mxCell>
        <mxCell id="PZrsTzekzqTFRi53L0Wj-1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#007CBD;strokeColor=none;fontColor=#FFFFFF;fontStyle=1;fontSize=22;labelBackgroundColor=none;" value="1" vertex="1">
